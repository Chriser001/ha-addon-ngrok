#!/usr/bin/ash
set -e

OPTIONS_FILE=/data/options.json
NGROK_CONFIG_PATH=/data/ngrok.yml

# 从 options.json 读取配置
AUTH_TOKEN=$(jq -r '.auth_token' "$OPTIONS_FILE")
REGION=$(jq -r '.region' "$OPTIONS_FILE")
LOCAL_PORT=$(jq -r '.local_port' "$OPTIONS_FILE")
URL_PARAM=$(jq -r '.url_param' "$OPTIONS_FILE")

# 生成最小 ngrok.yml，只包含 authtoken
cat > "$NGROK_CONFIG_PATH" <<EOF
version: 2
authtoken: ${AUTH_TOKEN}
EOF

# 用 CLI 参数启动，--url 直接映射你 dashboard 里设置的固定地址
exec ngrok http "$LOCAL_PORT" \
  --url "$URL_PARAM" \
  --region "$REGION" \
  --config "$NGROK_CONFIG_PATH"
